  },
  "description": "A full-featured browser DAW built on React and the Web Audio API",
  "private": true,
  "keywords": [
    "daw",
    "audio",
    "web-audio",
    "react",
    "browser-daw",
    "music-production",
    "plugin-system"
  ],
  "license": "MIT",
  "workspaces": [
    "plugin-sdk"
  ],
  "scripts": {
    "start": "python3 -m http.server 8080 --directory public",
    "dev": "echo 'Open public/wavr-pro.html in your browser — no build step needed.'",
    "serve-docs": "python3 -m http.server 8080 --directory docs",
    "open": "open public/wavr-pro.html || xdg-open public/wavr-pro.html"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
